# ── Kassenbuch CREDO – Umgebungsvariablen ─────────────────────────────
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#
# WICHTIG: Ohne .env startet das System NICHT (kein Fallback!)

# ── Mandant ──────────────────────────────────────────────────────────
# Kurzname des Mandanten (nur Kleinbuchstaben, Ziffern, Bindestrich)
# Bestimmt Container- und Volume-Namen, z.B. kb-fes-frontend
MANDANT=

# ── Datenbank ────────────────────────────────────────────────────────
# PostgreSQL-Passwort (min. 20 Zeichen, Sonderzeichen erlaubt)
DB_PASSWORD=

# ── Authentifizierung ────────────────────────────────────────────────
# JWT-Signaturschluessel (min. 32 Zeichen, zufaellig generieren!)
# Erzeugen mit: openssl rand -base64 48
JWT_SECRET=
