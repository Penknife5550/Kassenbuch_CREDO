# ── Kassenbuch CREDO – Umgebungsvariablen ─────────────────────────────
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env

# PostgreSQL-Passwort (min. 20 Zeichen, Sonderzeichen erlaubt)
DB_PASSWORD=changeme_in_production

# JWT-Signaturschlüssel (min. 32 Zeichen, zufällig generieren!)
# Erzeugen mit: openssl rand -base64 48
JWT_SECRET=changeme_jwt_secret_in_production
